# Use the "Connection string" URI format
SUPABASE_POSTGRES_URL=jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
SUPABASE_POSTGRES_USER=postgres.kjmbpxuqtpzkgkhndqum
SUPABASE_POSTGRES_PASSWORD=your_supabase_password_here

# Replace <password> with your Atlas database user password
MONGODB_ATLAS_URI=mongodb+srv://<username>:<password>@cluster.xxxxx.mongodb.net/medical_record_db?authSource=admin&retryWrites=true&w=majority

# Generate a secure random string (at least 32 characters for HS256)
# Example: openssl rand -base64 32
JWT_SECRET=your_secure_jwt_secret_at_least_32_chars_here
